<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- FastAPI WSGI Application Routing -->
    <handlers>
      <add name="PythonHandler" path="*" verb="*" modules="FastCgiModule" scriptProcessor="D:\Python311\python.exe|D:\Python311\Scripts\wfastcgi.py" resourceType="Unspecified" requireAccess="Script" />
    </handlers>

    <!-- Azure-specific settings -->
    <rewrite>
      <rules>
        <rule name="StaticFiles" stopProcessing="true">
          <conditions>
            <add input="true" pattern="false" />
          </conditions>
        </rule>
        <rule name="Configure Python" stopProcessing="true">
          <conditions>
            <add input="REQUEST_URI" pattern="^/static/.*" ignoreCase="true" negate="true" />
          </conditions>
          <action type="Rewrite" url="wsgi.py" />
        </rule>
      </rules>
    </rewrite>

    <!-- Keep connections alive -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Powered-By" value="FastAPI" />
      </customHeaders>
    </httpProtocol>

    <!-- Request filtering to accept large uploads -->
    <security>
      <requestFiltering>
        <requestLimits maxUrl="4096" maxQueryString="2048" maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>
  </system.webServer>
  
  <appSettings>
    <!-- FastAPI app entry point -->
    <add key="PYTHONPATH" value="D:\home\site\wwwroot" />
    <add key="WSGI_ALT_VIRTUALENV_HANDLER" value="main.app" />
    <add key="WSGI_ALT_VIRTUALENV_ACTIVATE_THIS" value="D:\home\site\wwwroot\venv\Scripts\activate_this.py" />
    <add key="WSGI_HANDLER" value="ptvs_virtualenv_proxy.handler" />
    <add key="PYTHONWARNINGS" value="ignore::DeprecationWarning" />
  </appSettings>
</configuration>
